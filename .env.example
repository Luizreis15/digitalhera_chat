# HeraChat — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# NÃO faça commit do .env.local

# Supabase — encontre em: https://app.supabase.com → Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# Nota: para projetos estáticos (sem build), as credenciais públicas
# (anon key) vão direto em js/config.js (não use chaves privadas ali).
